# Variáveis de ambiente do serviço (copiar para /opt/aeronav/aeronav.env e editar).
# NÃO versionar o arquivo real com segredos.

# Chave de assinatura de sessão — gere uma aleatória longa:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
APURADOR_SECRET=TROQUE-por-uma-chave-aleatoria-longa

# Login do organizador:
APURADOR_EMAIL=admin@aeronav.app
APURADOR_PASSWORD=TROQUE-esta-senha
# PIN exigido dos pilotos no /igcupload (vazio = qualquer um):
APURADOR_PIN=

# Endereço de escuta do gunicorn:
#   172.19.0.1:8050 = gateway da rede Docker "proxy" (alcançável pelo cloudflared, NÃO público)
#   127.0.0.1:8050  = só localhost (use com nginx no host)
APURADOR_BIND=172.19.0.1:8050

# Persistência em SQLite (sobrevive a restart):
APURADOR_BACKEND=sqlite
APURADOR_DB=/opt/aeronav/data/aeronav.db

# Atrás de HTTPS (nginx/cloudflared) → cookies Secure:
APURADOR_SECURE=1

# Identidade visual:
APURADOR_BRAND=Aeronav
APURADOR_TAGLINE=Apuração de navegação · Paramotor
